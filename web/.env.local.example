# 前端环境变量模板 —— 本地开发复制为 .env.local
# cp web/.env.local.example web/.env.local
#
# 注意：NEXT_PUBLIC_* 是构建期注入的。
# Docker 生产部署时这些值通过 docker-compose 的 build args 传入（见 docker-compose.yml 与根目录 .env），
# 本文件仅用于本地 `npm run dev` / `npm run build`。

# 后端 API 地址（本地开发用 http://localhost:8000）
NEXT_PUBLIC_API_URL=http://localhost:8000

# Supabase（浏览器使用 anon key）
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
